{
  "name": "valor-insurance-platform",
  "version": "0.1.0",
  "description": "Valor Financial Specialists Insurance Back Office Platform",
  "private": true,
  "scripts": {
    "dev": "next dev -p 2050",
    "dev:local": "bash -c 'unset DATABASE_URL && unset DIRECT_URL && npm run dev'",
    "build": "prisma generate && next build",
    "start": "next start -p 2050",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --compiler-options {\\\"module\\\":\\\"CommonJS\\\"} prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:ipipeline": "playwright test tests/e2e/integrations/ipipeline",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:auth": "playwright test tests/e2e/auth-and-navigation.spec.ts",
    "test:create-user": "ts-node scripts/create-test-user.ts",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:run": "vitest run",
    "test:unit:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\\\"module\\\":\\\"CommonJS\\\"} prisma/seed.ts"
  },
  "keywords": [
    "insurance",
    "back-office",
    "valor"
  ],
  "author": "BotMakers, Inc.",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-pdf/renderer": "^4.3.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.81.1",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.90.2",
    "clsx": "^2.1.1",
    "csv-stringify": "^6.6.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.554.0",
    "next": "^16.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^1.5.3",
    "react-hook-form": "^7.66.0",
    "recharts": "^2.15.4",
    "resend": "^6.4.2",
    "samlify": "^2.10.2",
    "stripe": "^17.6.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "xml-crypto": "^6.1.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "exceljs": "^4.4.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "supabase": "^2.58.5",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
