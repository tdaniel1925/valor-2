# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@host:port/database"
DIRECT_URL="postgresql://user:password@host:port/database"

# ============================================
# AUTHENTICATION (Supabase)
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# WINFLEX INTEGRATION (Life Insurance Quoting)cn
# ============================================
WINFLEX_API_KEY="your-winflex-api-key"
WINFLEX_API_SECRET="your-winflex-api-secret"
WINFLEX_PARTNER_ID="your-partner-id"
WINFLEX_BASE_URL="https://api.ebix.com/winflex/v1"
WINFLEX_ENABLED="false"
WINFLEX_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# IPIPELINE INTEGRATION (Term Life Quoting & E-App)
# ============================================
IPIPELINE_API_KEY="your-ipipeline-api-key"
IPIPELINE_API_SECRET="your-ipipeline-api-secret"
IPIPELINE_PARTNER_ID="your-partner-id"
IPIPELINE_BASE_URL="https://api.ipipeline.com/v1"
IPIPELINE_ENABLED="false"
IPIPELINE_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# RATEWATCH INTEGRATION (Annuity Rates)
# ============================================
RATEWATCH_API_KEY="your-ratewatch-api-key"
RATEWATCH_API_SECRET="your-ratewatch-api-secret"
RATEWATCH_BASE_URL="https://api.annuityratewatch.com/v1"
RATEWATCH_ENABLED="false"
RATEWATCH_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# IGO E-APP INTEGRATION (Life Insurance Applications)
# ============================================
IGO_API_KEY="your-igo-api-key"
IGO_API_SECRET="your-igo-api-secret"
IGO_PARTNER_ID="your-partner-id"
IGO_BASE_URL="https://api.ipipeline.com/igo/v1"
IGO_ENVIRONMENT="sandbox" # or "production"
IGO_ENABLED="false"

# ============================================
# FIRELIGHT INTEGRATION (Annuity Applications)
# ============================================
FIRELIGHT_API_KEY="your-firelight-api-key"
FIRELIGHT_API_SECRET="your-firelight-api-secret"
FIRELIGHT_PARTNER_ID="your-partner-id"
FIRELIGHT_BASE_URL="https://api.hexure.com/firelight/v1"
FIRELIGHT_ENVIRONMENT="sandbox" # or "production"
FIRELIGHT_ENABLED="false"

# ============================================
# STRIPE (Subscription Billing)
# ============================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_STARTER_PRICE_ID="price_your-starter-price-id"
STRIPE_PROFESSIONAL_PRICE_ID="price_your-professional-price-id"
STRIPE_ENTERPRISE_PRICE_ID="price_your-enterprise-price-id"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-signing-secret"

# ============================================
# MULTI-TENANCY (SaaS Configuration)
# ============================================
NEXT_PUBLIC_ROOT_DOMAIN="valorfs.app"
NEXT_PUBLIC_WILDCARD_SUBDOMAIN_ENABLED="true"
TENANT_ISOLATION_ENABLED="true"

# Default tenant for root domain (valorfs.app with no subdomain)
# Get the tenant ID from your database: SELECT id, slug, name FROM tenants LIMIT 1;
DEFAULT_TENANT_ID="your-tenant-uuid-from-database"
DEFAULT_TENANT_SLUG="valor"
DEFAULT_TENANT_NAME="Valor"

# ============================================
# SMARTOFFICE INTELLIGENCE SYSTEM
# ============================================
SMARTOFFICE_SYNC_ENABLED="true"
SMARTOFFICE_STORAGE_BUCKET="smartoffice-reports"
SMARTOFFICE_WEBHOOK_SECRET="your-random-32-char-string-here"
SMARTOFFICE_MAX_FILE_SIZE_MB="50"
SMARTOFFICE_REPORTS_EMAIL_DOMAIN="reports.valorfs.app"

# ============================================
# AI CHAT ASSISTANT (Anthropic Claude)
# ============================================
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key-here"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
SMARTOFFICE_CHAT_ENABLED="true"
SMARTOFFICE_CHAT_MAX_TOKENS="4000"
SMARTOFFICE_CHAT_RATE_LIMIT="100" # requests per hour per tenant

# ============================================
# APPLICATION SETTINGS
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:2050"
NODE_ENV="development"

# ============================================
# EMAIL NOTIFICATIONS (Resend)
# ============================================
RESEND_API_KEY="re_your-resend-api-key-here"
FROM_EMAIL="notifications@valorfs.app"
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="re_your-resend-api-key-here"

# ============================================
# OPTIONAL: DOCUMENT STORAGE
# ============================================
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_S3_BUCKET="your-bucket-name"
# AWS_REGION="us-east-1"
